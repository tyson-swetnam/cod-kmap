@article{halpern_priorities_2023,
	title = {Priorities for synthesis research in ecology and environmental science},
	volume = {14},
	issn = {2150-8925, 2150-8925},
	url = {https://esajournals.onlinelibrary.wiley.com/doi/10.1002/ecs2.4342},
	doi = {10.1002/ecs2.4342},
	abstract = {Abstract
            Synthesis research in ecology and environmental science improves understanding, advances theory, identifies research priorities, and supports management strategies by linking data, ideas, and tools. Accelerating environmental challenges increases the need to focus synthesis science on the most pressing questions. To leverage input from the broader research community, we convened a virtual workshop with participants from many countries and disciplines to examine how and where synthesis can address key questions and themes in ecology and environmental science in the coming decade. Seven priority research topics emerged: (1) diversity, equity, inclusion, and justice (DEIJ), (2) human and natural systems, (3) actionable and use‐inspired science, (4) scale, (5) generality, (6) complexity and resilience, and (7) predictability. Additionally, two issues regarding the general practice of synthesis emerged: the need for increased participant diversity and inclusive research practices; and increased and improved data flow, access, and skill‐building. These topics and practices provide a strategic vision for future synthesis in ecology and environmental science.},
	language = {en},
	number = {1},
	urldate = {2024-11-11},
	journal = {Ecosphere},
	author = {Halpern, Benjamin S. and Boettiger, Carl and Dietze, Michael C. and Gephart, Jessica A. and Gonzalez, Patrick and Grimm, Nancy B. and Groffman, Peter M. and Gurevitch, Jessica and Hobbie, Sarah E. and Komatsu, Kimberly J. and Kroeker, Kristy J. and Lahr, Heather J. and Lodge, David M. and Lortie, Christopher J. and Lowndes, Julie S. S. and Micheli, Fiorenza and Possingham, Hugh P. and Ruckelshaus, Mary H. and Scarborough, Courtney and Wood, Chelsea L. and Wu, Grace C. and Aoyama, Lina and Arroyo, Eva E. and Bahlai, Christie A. and Beller, Erin E. and Blake, Rachael E. and Bork, Karrigan S. and Branch, Trevor A. and Brown, Norah E. M. and Brun, Julien and Bruna, Emilio M. and Buckley, Lauren B. and Burnett, Jessica L. and Castorani, Max C. N. and Cheng, Samantha H. and Cohen, Sarah C. and Couture, Jessica L. and Crowder, Larry B. and Dee, Laura E. and Dias, Arildo S. and Diaz‐Maroto, Ignacio J. and Downs, Martha R. and Dudney, Joan C. and Ellis, Erle C. and Emery, Kyle A. and Eurich, Jacob G. and Ferriss, Bridget E. and Fredston, Alexa and Furukawa, Hikaru and Gagné, Sara A. and Garlick, Sarah R. and Garroway, Colin J. and Gaynor, Kaitlyn M. and González, Angélica L. and Grames, Eliza M. and Guy‐Haim, Tamar and Hackett, Ed and Hallett, Lauren M. and Harms, Tamara K. and Haulsee, Danielle E. and Haynes, Kyle J. and Hazen, Elliott L. and Jarvis, Rebecca M. and Jones, Kristal and Kandlikar, Gaurav S. and Kincaid, Dustin W. and Knope, Matthew L. and Koirala, Anil and Kolasa, Jurek and Kominoski, John S. and Koricheva, Julia and Lancaster, Lesley T. and Lawlor, Jake A. and Lowman, Heili E. and Muller‐Karger, Frank E. and Norman, Kari E. A. and Nourn, Nan and O'Hara, Casey C. and Ou, Suzanne X. and Padilla‐Gamino, Jacqueline L. and Pappalardo, Paula and Peek, Ryan A. and Pelletier, Dominique and Plont, Stephen and Ponisio, Lauren C. and Portales‐Reyes, Cristina and Provete, Diogo B. and Raes, Eric J. and Ramirez‐Reyes, Carlos and Ramos, Irene and Record, Sydne a